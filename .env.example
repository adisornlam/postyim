# Database
DATABASE_URL=postgresql://localhost:5432/postyim

# Amazon PA-API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_REGION=us-east-1
# Use mock catalog when credentials are missing (dev default)
AMAZON_MOCK=true

# Set to false in production when PA-API credentials are configured
# AMAZON_MOCK=false

# Job endpoints
CRON_SECRET=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_DRAFT=gemini-2.0-flash
GEMINI_MODEL_FINAL=gemini-2.0-pro
# Use mock review generator when API key is missing
GEMINI_MOCK=true

# Set to false in production when GEMINI_API_KEY is configured
# GEMINI_MOCK=false

# Required in production for cron jobs and /api/jobs/* endpoints
CRON_SECRET=

# Admin Auth (MVP)
ADMIN_PASSWORD=
AUTH_SECRET=change-me-in-production

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Postyim
