# Database
DATABASE_URL=postgresql://localhost:5432/postyim

# Encryption for credentials stored in app_settings (32-byte base64 key)
# Generate: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=

# Optional legacy fallbacks during migration (prefer Admin → Settings UI)
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=
# AMAZON_REGION=us-east-1
# AMAZON_MOCK=true
# GEMINI_API_KEY=
# GEMINI_MODEL_DRAFT=gemini-2.0-flash
# GEMINI_MODEL_FINAL=gemini-2.0-pro
# GEMINI_MOCK=true
# CRON_SECRET=

# Admin Auth (bootstrap only)
ADMIN_EMAIL=admin@postyim.com
ADMIN_PASSWORD=PostyimAdmin2026!
AUTH_SECRET=change-me-in-production

# Site (bootstrap only — client bundle may still need rebuild for NEXT_PUBLIC_*)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Postyim

# Localhost → production content sync (optional)
# Local:      copy to .env.local and fill in the secret
# Production: create .env.production.local on the server (not committed to git)
#   NEXT_PUBLIC_SITE_URL=https://postyim.com
#   POSTYIM_REMOTE_URL=https://postyim.com
#   REMOTE_SYNC_SECRET=
POSTYIM_REMOTE_URL=https://postyim.com
REMOTE_SYNC_SECRET=
